# ── Stage 1: build / install dependencies ────────────────────────────────────
FROM python:3.12-slim AS builder

WORKDIR /app

# Install uv for fast dependency resolution
RUN pip install --no-cache-dir uv

# Copy dependency manifests first (layer-cache friendly)
COPY pyproject.toml uv.lock ./

# Install production deps into a local venv
RUN uv sync --no-dev --frozen

# ── Stage 2: lean runtime image ───────────────────────────────────────────────
FROM python:3.12-slim AS runtime

WORKDIR /app

# Create a non-root user to run the app
RUN groupadd --system app && useradd --system --gid app --no-create-home app

# Copy the pre-built virtual environment from builder
COPY --from=builder --chown=app:app /app/.venv /app/.venv

# Copy Chainlit app source
COPY --chown=app:app chainlit_app.py ./

# Make sure the venv's bin directory is on PATH
ENV PATH="/app/.venv/bin:$PATH" \
    PYTHONUNBUFFERED=1

# Point Chainlit at the FastAPI agent endpoint on the compose network
ENV RESEARCH_API_URL="http://agent:8000/research"

USER app

EXPOSE 9000

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
    CMD ["python", "-c", "import urllib.request; urllib.request.urlopen('http://127.0.0.1:9000/')"]

CMD ["chainlit", "run", "chainlit_app.py", "--host", "0.0.0.0", "--port", "9000", "--headless"]
